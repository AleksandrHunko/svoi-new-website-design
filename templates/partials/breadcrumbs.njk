{# @unless ($breadcrumbs->isEmpty()) #}
{% if breadcrumbs and breadcrumbs.length %}
    <div class="flex gap-2 w-full max-w-[1440px] mt-5 px-4 md:px-8 mx-auto">
        {% for breadcrumb in breadcrumbs %}
            {% if breadcrumb.url and not loop.last %}
                <a
                    class="hover:text-colored text-small text-[#959595] font-normal"
                    href="{{ breadcrumb.url }}"
                    >
                    {{ breadcrumb.title }}
                </a>
                <svg
                    class="w-2 h-4 shrink-0 cursor-pointer"
                    fill="#959595"
                    width="18"
                    height="29"
                    viewBox="0 0 18 29"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    >
                    <path
                        d="M11.1611 14.1775L0 3.01642L2.97751 0L17.1551 14.1775L2.97751 28.3551L0 25.3387L11.1611 14.1775Z"
                    />
                </svg>
            {% else %}
                <p class="text-small font-normal truncate">
                    {{ breadcrumb.title }}
                </p>
            {% endif %}
        {% endfor %}
    </div>
{% endif %}
